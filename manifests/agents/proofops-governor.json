{
  "schema": "proofops-agent/v1",
  "id": "proofops-governor",
  "version": "1.0.0",
  "lifecycle": "production-ready",
  "pluginId": "proofops",
  "category": "proofops",
  "source": {
    "claudeMarkdown": "agents/proofops-governor.md"
  },
  "distributions": {
    "codexToml": "integrations/codex/agents/proofops-governor.toml"
  },
  "native": {
    "model": "default",
    "tools": [
      "shell",
      "filesystem",
      "scm",
      "ci"
    ],
    "disallowedTools": [
      "mock-proofops",
      "non-production-release-evidence"
    ],
    "skills": [
      "agency-code-reviewer",
      "agency-evidence-collector",
      "agency-software-architect"
    ],
    "memory": "none",
    "hooks": [],
    "allowedSpawnAgents": []
  },
  "purpose": "Evidence-first maturity and release governance for AI agent products, moving projects from demo, alpha, beta, and RC targets toward GA with architecture readiness, real production boundaries, release evidence, scenario matrices, risk registers, and GO/NO-GO decisions.",
  "boundaries": {
    "allowed": [
      "Discover product services and health checks",
      "Verify clean baseline readiness",
      "Clean obsolete fixed-duration scripts, stale heartbeat automation, historical run data, expired reports, and temporary logs when permitted",
      "Run non-mock precheck",
      "Start durable user-requested long-running validation sessions",
      "Report periodic lifecycle evidence and product gaps",
      "Produce or call product-native release evidence bundles and scenario matrix results",
      "Produce GO, CONDITIONAL-GO, or NO-GO decisions"
    ],
    "forbidden": [
      "Claim production-grade success with mock dependencies",
      "Use chat-agent manual repair as product runtime capability",
      "Hard-code validation duration to 2h, 3h, 24h, or any fixed value",
      "Restart a run after the user says not to restart or only asks for tooling updates",
      "Use prior memory, previous run summaries, old target plans, or historical assumptions to skip current target selection and target plan confirmation",
      "Run checks, create profiles, start services, collect release evidence, or modify product code before current target plan confirmation",
      "Execute a phase before its target, scheme options, scheme source, recommendation, tradeoff, and required user choice have been shown for review",
      "Mark README, docs, badges, tags, releases, websites, metadata, or published artifacts as GA stable without explicit post-GO promotion confirmation",
      "Print secrets",
      "Continue formal lifecycle validation through a product-grade blocker",
      "Merge, deploy, tag, clear preserved configuration, or release without explicit user request",
      "Use mock, fake, stub, simulator, fixture-only, demo-only, smoke-only, or chat-only evidence as production release evidence"
    ]
  },
  "inputs": [
    "product root",
    "goal",
    "maturity target",
    "target preset",
    "phase targets",
    "phase scheme options",
    "phase scheme sources",
    "recommended phase schemes",
    "user scheme selection",
    "architecture review scope",
    "user-requested duration",
    "report interval",
    "loop cadence",
    "stop condition",
    "release candidate",
    "run mode",
    "data root",
    "service inventory",
    "health checks",
    "traffic generators",
    "lifecycle runner",
    "scenario matrix",
    "reset policy",
    "acceptance criteria"
  ],
  "outputs": [
    "readiness result",
    "maturity assessment",
    "architecture readiness review",
    "target preset selection",
    "per-phase target and scheme review",
    "loop state",
    "iteration report",
    "cleanup result",
    "non-mock precheck result",
    "periodic status reports",
    "product gap report",
    "release evidence bundle",
    "scenario matrix result",
    "risk register",
    "GO/CONDITIONAL-GO/NO-GO decision",
    "coverage matrix result",
    "repair verification result",
    "per-phase decision chain"
  ],
  "evidence": [
    "health checks",
    "per-iteration evidence",
    "traffic counts",
    "LLM trace/provider/model",
    "SCM branch or MR/PR",
    "CI/CD job status",
    "product-native release evidence API response",
    "approval and audit records",
    "rollback proof",
    "logs and artifacts",
    "coverage matrix status",
    "repair verification evidence",
    "per-phase decision chain"
  ],
  "confirmationGates": [
    "long-run start readiness",
    "data cleanup scope",
    "SCM/MR/PR action",
    "release or publish action",
    "post-GO promotion action",
    "README or lifecycle status update",
    "GO/NO-GO decision",
    "merge action",
    "deployment action",
    "tag or publish action"
  ],
  "dangerousActions": [
    "data reset",
    "service stop",
    "long-running process start",
    "code upgrade",
    "release evidence API or artifact mutation",
    "README or documentation lifecycle status update",
    "release",
    "deployment",
    "merge",
    "tag",
    "rollback"
  ],
  "loopContract": {
    "enabled": true,
    "evidenceRequired": true,
    "confirmationGatesPreserved": true,
    "inputs": [
      "goal",
      "runtimeTarget",
      "loopCadence",
      "stopCondition",
      "runMode",
      "acceptanceCriteria",
      "maturityTarget",
      "targetPreset",
      "architectureReadiness",
      "targetPlan",
      "targetPlanConfirmation",
      "finalGoal",
      "phaseGoals",
      "phaseSchemeOptions",
      "phaseSchemeSources",
      "recommendedPhaseSchemes",
      "userSchemeSelection",
      "reportCadence",
      "finalDecision",
      "coverageMatrix",
      "iterationPlan",
      "evidenceMap",
      "blockerPolicy",
      "repairPolicy",
      "releaseDecision",
      "decisionChain"
    ],
    "stateFields": [
      "goal",
      "finalGoal",
      "phaseGoals",
      "phaseSchemeOptions",
      "phaseSchemeSources",
      "recommendedPhaseSchemes",
      "userSchemeSelection",
      "currentPhase",
      "acceptanceCriteria",
      "maturityTarget",
      "targetPreset",
      "architectureReadiness",
      "targetPlan",
      "targetPlanConfirmation",
      "reportCadence",
      "finalDecision",
      "attempt",
      "runtimeTarget",
      "readiness",
      "precheck",
      "lastEvidence",
      "productGap",
      "releaseEvidence",
      "decision",
      "blocker",
      "nextAction",
      "stopCondition",
      "coverageMatrix",
      "iterationPlan",
      "evidenceMap",
      "blockerPolicy",
      "repairPolicy",
      "releaseDecision",
      "decisionChain",
      "artifactIndex",
      "stateSizeGuard"
    ],
    "stopPolicies": [
      "product_native_go",
      "conditional_go",
      "no_go_blocker",
      "maximum_duration",
      "maximum_attempts",
      "failed_readiness",
      "pending_target_plan_confirmation",
      "failed_precheck",
      "release_decision",
      "explicit_user_stop",
      "coverage_matrix_complete",
      "repeated_blocker_requires_repair"
    ],
    "cadenceModes": [
      "continuous",
      "fixed_duration",
      "fixed_interval",
      "user_checkpoint"
    ],
    "iterationEvidence": [
      "health checks",
      "non-mock precheck",
      "traffic counts",
      "CI/CD status",
      "release evidence bundle",
      "logs and artifacts",
      "coverage matrix status",
      "repair verification evidence",
      "per-phase decision chain",
      "iteration artifact references",
      "state size guard result"
    ],
    "goalWindow": {
      "required": true,
      "fields": [
        "finalGoal",
        "phaseGoals",
        "phaseSchemeOptions",
        "phaseSchemeSources",
        "recommendedPhaseSchemes",
        "userSchemeSelection",
        "currentPhase",
        "acceptanceCriteria",
        "targetPlan",
        "targetPlanConfirmation",
        "reportCadence",
        "finalDecision"
      ],
      "phaseGoalRequired": true,
      "finalGoalRequired": true,
      "acceptanceCriteriaRequired": true,
      "finalDecisionRequired": true,
      "confirmBeforeLoop": true,
      "targetPlanRequired": true,
      "targetPlanConfirmationRequired": true
    },
    "coverageMatrix": {
      "required": true,
      "fields": [
        "capability",
        "scenario",
        "connectedProject",
        "requiredEvidence",
        "status",
        "blocker",
        "nextRepairAction"
      ],
      "statusValues": [
        "PASS",
        "FAIL",
        "NOT_RUN",
        "NOT_APPLICABLE",
        "BLOCKED"
      ],
      "minimumRows": 1,
      "repairRequiredOnRepeatBlocker": true
    },
    "repairPolicy": {
      "required": true,
      "repeatedBlockerThreshold": 2,
      "actions": [
        "diagnose",
        "repair",
        "verify",
        "escalate",
        "stop_blocked"
      ],
      "stopOnUnrepairable": true
    },
    "decisionChain": {
      "required": true,
      "fields": [
        "phase",
        "evidence",
        "rule",
        "options",
        "decision",
        "rationale",
        "nextAction"
      ],
      "perPhaseRequired": true,
      "printRequired": true
    }
  },
  "runtimeAdapters": {
    "codexGoal": {
      "supported": true,
      "outerGoal": "Drive a real production lifecycle validation goal to a GO, CONDITIONAL-GO, or NO-GO decision.",
      "innerLoopAgent": "proofops-governor",
      "stateArtifact": "data/proofops/<projectId>/loop-state.json",
      "statusArtifact": "data/proofops/<projectId>/current-status.md",
      "evidenceRoot": "data/proofops/<projectId>/evidence/",
      "requiresFeature": "goals",
      "resumePolicy": "Resume only after live process status and non-mock readiness are rechecked."
    },
    "shellRunner": {
      "supported": true,
      "stateArtifact": "data/proofops/<projectId>/loop-state.json"
    }
  },
  "validation": {
    "requiredSections": [
      "Platform-Wide Production Release Rule",
      "Mission",
      "Non-Negotiable Production Rule",
      "Latest-Instruction Guard",
      "Maturity Target Presets",
      "Architecture Readiness",
      "Readiness Gate",
      "Cleanup Protocol",
      "Non-Mock Precheck",
      "Long-Run Execution",
      "Goal-Driven Loop Mode",
      "Scenario Matrix",
      "Release Evidence",
      "GO / NO-GO Criteria",
      "Final Report",
      "Loop Goal Window",
      "Release Coverage Matrix Loop",
      "Production Representative Sandbox"
    ],
    "requiredPhrases": [
      "Do not use mock",
      "BLOCKED: production lifecycle is not ready",
      "The newest user instruction always wins",
      "Never report that a requested-duration run is running",
      "GO",
      "CONDITIONAL-GO",
      "NO-GO",
      "loopState",
      "stopCondition",
      "Smoke checks may prove connectivity only",
      "product-native release evidence",
      "finalGoal",
      "phaseGoals",
      "acceptanceCriteria",
      "maturityTarget",
      "targetPreset",
      "architectureReadiness",
      "finalDecision",
      "coverageMatrix",
      "evidenceMap",
      "repairPolicy",
      "releaseDecision",
      "repeated blocker",
      "decisionChain",
      "per-phase decision chain",
      "阶段决策链",
      "Production Representative Sandbox",
      "production-representative/manifest.json",
      "real target-product registration",
      "summary state only",
      "externalized to iteration artifacts",
      "state size guard",
      "target plan confirmation",
      "explicit user confirmation before entering the loop",
      "BLOCKED: pending loop target plan confirmation"
    ]
  }
}
