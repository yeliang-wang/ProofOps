{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proofops.local/schemas/proposal.schema.json",
  "title": "proofops offline proposal manifest",
  "type": "object",
  "required": ["schema", "title", "created_at", "tool", "toolkit_root", "project_root", "changes"],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "proofops-proposal/v1"
    },
    "title": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "tool": {
      "type": "string",
      "enum": ["codex", "claude-code", "all"]
    },
    "toolkit_root": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relpath", "source_path", "installed_path", "proposed_file", "diff_file", "source_sha256", "installed_sha256", "tool"],
        "additionalProperties": true
      }
    }
  }
}
